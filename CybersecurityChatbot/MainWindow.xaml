<Window x:Class="CybersecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CybersecurityChatbot"
        Title="CipherGuard Lupus — Cybersecurity Awareness" Height="800" Width="1180"
        MinHeight="680" MinWidth="920"
        Background="#0A0F1E">

    <Window.Resources>
        <!-- I define all the colors as reusable brushes so I can easily change the theme in one place.
             Instead of hard-coding #4F46E5 everywhere, I use {StaticResource UserBubble} which is cleaner. -->
        <!-- ── Colour palette ──────────────────────────────────────────────── -->
        <SolidColorBrush x:Key="PanelBg"      Color="#111827"/>
        <SolidColorBrush x:Key="ChatBg"       Color="#0D1B2A"/>
        <SolidColorBrush x:Key="UserBubble"   Color="#4F46E5"/>
        <SolidColorBrush x:Key="BotBubble"    Color="#1E3A5F"/>
        <SolidColorBrush x:Key="AccentPurple" Color="#7C3AED"/>
        <SolidColorBrush x:Key="TextLight"    Color="#E2E8F0"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#64748B"/>
        <SolidColorBrush x:Key="BorderColor"  Color="#1E293B"/>

        <!-- I style the quick-topic buttons here so they have consistent hover/click effects.
             Using a custom template lets me control the exact appearance and rounded corners. -->
        <!-- ── Quick-topic button style ────────────────────────────────── -->
        <Style x:Key="QuickTopicButton" TargetType="Button">
            <Setter Property="Background"   Value="#1E293B"/>
            <Setter Property="Foreground"   Value="#93C5FD"/>
            <Setter Property="BorderBrush"  Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="10,5"/>
            <Setter Property="Margin"       Value="3,2"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#334155"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#4F46E5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- The Send button style is similar to quick-topic buttons but with a purple highlight
             since it's the primary action. On hover, it gets darker; on click, even darker. -->
        <!-- ── Send button style ───────────────────────────────────────── -->
        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Background"   Value="#4F46E5"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"     Value="14"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="16,10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#6D28D9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#5B21B6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- The user message template is a right-aligned bubble with the sender name, message text, and timestamp.
             I use CornerRadius="16,4,16,16" to make a rounded bubble with a sharp corner on the bottom-left
             (a design convention that shows this came from the user). -->
        <!-- ── User message bubble template ────────────────────────────– -->
        <DataTemplate x:Key="UserMessageTemplate">
            <Grid Margin="0,4">
                <Border HorizontalAlignment="Right"
                        Background="{StaticResource UserBubble}"
                        CornerRadius="16,4,16,16"
                        Padding="14,10"
                        MaxWidth="500"
                        Margin="80,0,4,0">
                    <StackPanel>
                        <TextBlock Text="You"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="#A5B4FC"
                                   Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding Text}"
                                   TextWrapping="Wrap"
                                   FontSize="14"
                                   Foreground="White"
                                   LineHeight="20"/>
                        <TextBlock Text="{Binding Time}"
                                   FontSize="10"
                                   Foreground="#C7D2FE"
                                   HorizontalAlignment="Right"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- The bot message template is left-aligned with a wolf emoji (🐺) in the sender label.
             CornerRadius="4,16,16,16" creates a sharp corner on the top-left to distinguish bot messages visually. -->
        <!-- ── Bot message bubble template ─────────────────────────────– -->
        <DataTemplate x:Key="BotMessageTemplate">
            <Grid Margin="0,4">
                <Border HorizontalAlignment="Left"
                        Background="{StaticResource BotBubble}"
                        CornerRadius="4,16,16,16"
                        Padding="14,10"
                        MaxWidth="520"
                        Margin="4,0,80,0">
                    <StackPanel>
                        <TextBlock Text="🐺 Lupus"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="#60A5FA"
                                   Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding Text}"
                                   TextWrapping="Wrap"
                                   FontSize="14"
                                   Foreground="#E2E8F0"
                                   LineHeight="20"/>
                        <TextBlock Text="{Binding Time}"
                                   FontSize="10"
                                   Foreground="#93C5FD"
                                   HorizontalAlignment="Right"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- I use the MessageTemplateSelector to automatically pick the right template for each message.
             It checks the IsUser flag on the ChatMessage and returns UserTemplate or BotTemplate accordingly. -->
        <!-- ── Template selector for dual-template binding ──────────────– -->
        <local:MessageTemplateSelector x:Key="MsgTemplateSelector"
            UserTemplate="{StaticResource UserMessageTemplate}"
            BotTemplate="{StaticResource BotMessageTemplate}"/>
    </Window.Resources>

    <!-- ── Root layout: 3 rows ────────────────────────────────────────── -->
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="110"/>   <!-- Banner -->
            <RowDefinition Height="*"/>     <!-- Content -->
            <RowDefinition Height="Auto"/>  <!-- Input bar -->
        </Grid.RowDefinitions>

        <!-- ══ ROW 0: Banner ══════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="#111827"
                BorderBrush="#1E293B"
                BorderThickness="1"
                CornerRadius="16"
                Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <Border Grid.Column="0" Width="80" Height="80"
                        CornerRadius="12" ClipToBounds="True" Margin="0,0,14,0">
                    <Image x:Name="BannerImage" Stretch="UniformToFill" SnapsToDevicePixels="True"/>
                </Border>

                <!-- Title + subtitle -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="🔐 CipherGuard Lupus"
                               FontSize="26" FontWeight="Bold"
                               Foreground="#E2E8F0"/>
                    <TextBlock Text="Cybersecurity Awareness Companion for South African Citizens"
                               FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Status pill -->
                <Border Grid.Column="2"
                        Background="#0F2027"
                        BorderBrush="#134E4A"
                        BorderThickness="1"
                        CornerRadius="20"
                        Padding="14,6"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#34D399" Margin="0,0,6,0"
                                 VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatusText"
                                   Text="Online"
                                   Foreground="#34D399"
                                   FontSize="12" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ══ ROW 1: Main content (ASCII | Chat) ════════════════════════ -->
        <Grid Grid.Row="1" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="290"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left: ASCII art panel ────────────────────────────── -->
            <Border Grid.Column="0"
                    Background="#080E1C"
                    BorderBrush="#1E293B"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="⚡ Lupus Signature"
                               Foreground="#A78BFA"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Margin="0,0,0,8"/>

                    <TextBox x:Name="AsciiTextBox"
                             Grid.Row="1"
                             FontFamily="Consolas"
                             FontSize="11"
                             Foreground="#60A5FA"
                             Background="Transparent"
                             BorderThickness="0"
                             IsReadOnly="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"/>

                    <!-- Memory status panel -->
                    <Border Grid.Row="2"
                            Background="#0F172A"
                            BorderBrush="#1E293B"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="8,6"
                            Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="🧠 Memory"
                                       Foreground="#7C3AED"
                                       FontSize="11" FontWeight="Bold"
                                       Margin="0,0,0,4"/>
                            <TextBlock x:Name="MemoryDisplay"
                                       Text="No user info stored yet."
                                       Foreground="#475569"
                                       FontSize="11"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ── Right: Chat panel ─────────────────────────────────── -->
            <Border Grid.Column="2"
                    Background="#0D1B2A"
                    BorderBrush="#1E293B"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Header -->
                        <RowDefinition Height="*"/>     <!-- Messages -->
                        <RowDefinition Height="Auto"/>  <!-- Typing indicator -->
                        <RowDefinition Height="Auto"/>  <!-- Quick topics -->
                    </Grid.RowDefinitions>

                    <!-- Chat header -->
                    <Border Grid.Row="0"
                            Background="#111827"
                            CornerRadius="10"
                            Padding="12,8"
                            Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="💬 CipherGuard Lupus Chat"
                                       Foreground="#E2E8F0"
                                       FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" x:Name="TopicLabel"
                                       Text=""
                                       Foreground="#60A5FA"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Scrollable message area -->
                    <ScrollViewer Grid.Row="1"
                                  x:Name="ChatScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="4,0">
                        <ItemsControl x:Name="ChatItemsControl"
                                      ItemTemplateSelector="{StaticResource MsgTemplateSelector}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Typing indicator (hidden by default) -->
                    <Border Grid.Row="2"
                            x:Name="TypingBorder"
                            HorizontalAlignment="Left"
                            Background="#1E3A5F"
                            CornerRadius="12"
                            Padding="12,6"
                            Margin="4,4,0,0"
                            Visibility="Collapsed">
                        <TextBlock x:Name="TypingLabel"
                                   Text="🐺 Lupus is typing…"
                                   Foreground="#93C5FD"
                                   FontSize="12"/>
                    </Border>

                    <!-- Quick topic chips -->
                    <Border Grid.Row="3"
                            Background="#0A0F1E"
                            CornerRadius="10"
                            Padding="8,6"
                            Margin="0,8,0,0">
                        <StackPanel>
                            <TextBlock Text="Quick topics:"
                                       Foreground="#475569"
                                       FontSize="11"
                                       Margin="2,0,0,4"/>
                            <WrapPanel>
                                <Button Content="🔑 Passwords"  Style="{StaticResource QuickTopicButton}" Click="QuickTopic_Click" Tag="Tell me about password safety"/>
                                <Button Content="🎣 Phishing"   Style="{StaticResource QuickTopicButton}" Click="QuickTopic_Click" Tag="Give me a phishing tip"/>
                                <Button Content="⚠️ Scams"      Style="{StaticResource QuickTopicButton}" Click="QuickTopic_Click" Tag="How do I avoid scams?"/>
                                <Button Content="🔒 Privacy"    Style="{StaticResource QuickTopicButton}" Click="QuickTopic_Click" Tag="Tell me about privacy"/>
                                <Button Content="🦠 Malware"    Style="{StaticResource QuickTopicButton}" Click="QuickTopic_Click" Tag="What is malware?"/>
                                <Button Content="🌐 VPN"        Style="{StaticResource QuickTopicButton}" Click="QuickTopic_Click" Tag="Tell me about VPNs"/>
                                <Button Content="🔑 2FA"        Style="{StaticResource QuickTopicButton}" Click="QuickTopic_Click" Tag="Explain two-factor authentication"/>
                                <Button Content="📡 Wi-Fi"      Style="{StaticResource QuickTopicButton}" Click="QuickTopic_Click" Tag="Wi-Fi security tips"/>
                                <Button Content="💀 Ransomware" Style="{StaticResource QuickTopicButton}" Click="QuickTopic_Click" Tag="Tell me about ransomware"/>
                                <Button Content="📋 Help"       Style="{StaticResource QuickTopicButton}" Click="QuickTopic_Click" Tag="help"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ══ ROW 2: Input bar ═══════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="#111827"
                BorderBrush="#1E293B"
                BorderThickness="1"
                CornerRadius="14"
                Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#1E293B"
                        BorderBrush="#334155"
                        BorderThickness="1"
                        CornerRadius="10">
                    <TextBox x:Name="UserInputTextBox"
                             Height="44"
                             VerticalContentAlignment="Center"
                             Padding="12,0"
                             FontSize="14"
                             Background="Transparent"
                             Foreground="#E2E8F0"
                             BorderThickness="0"
                             CaretBrush="#7C3AED"
                             KeyDown="UserInputTextBox_KeyDown"
                             ToolTip="Type your message and press Enter or click Send"/>
                </Border>

                <Button Grid.Column="2"
                        x:Name="SendButton"
                        Content="Send ➤"
                        Height="44"
                        Style="{StaticResource SendButtonStyle}"
                        Click="SendButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
